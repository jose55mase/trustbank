<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Structured log pattern: timestamp, level, component (logger), and message with contextual fields -->
    <property name="LOG_PATTERN"
              value="timestamp=%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z', UTC} level=%-5level component=%logger{36} %msg%n"/>

    <!-- Console appender with structured format -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Root logger at INFO level -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Bot package loggers -->
    <logger name="com.discord.bot" level="INFO"/>
    <logger name="com.discord.bot.listener" level="INFO"/>
    <logger name="com.discord.bot.command" level="INFO"/>
    <logger name="com.discord.bot.monitor" level="INFO"/>
    <logger name="com.discord.bot.message" level="INFO"/>
    <logger name="com.discord.bot.config" level="INFO"/>

    <!-- JDA library logging at WARN to reduce noise -->
    <logger name="net.dv8tion.jda" level="WARN"/>

    <!-- Spring framework at WARN to reduce noise -->
    <logger name="org.springframework" level="WARN"/>

</configuration>
