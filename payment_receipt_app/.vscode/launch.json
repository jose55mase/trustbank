{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Web - Dev (localhost)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "chrome",
            "flutterMode": "release",
            "args": [
                "--web-port",
                "8080",
                "--dart-define=ENV=dev"
            ]
        },
        {
            "name": "Flutter Web - Prod",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "chrome",
            "flutterMode": "release",
            "args": [
                "--web-port",
                "8080",
                "--dart-define=ENV=prod"
            ]
        }
    ]
}
